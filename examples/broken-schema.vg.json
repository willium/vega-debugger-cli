{
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "width": 200,
  "height": 100,
  "data": [
    {
      "name": "table",
      "values": [
        { "x": 10, "y": 20 }
      ]
    }
  ],
  "marks": [
    {
      "type": "rect",
      "from": { "data": "table" },
      "encode": {
        "enter": {
          "x": { "field": "x" },
          "y": { "field": "y" },
          "fill": { "value": 123 }
        }
      }
    }
  ]
}
